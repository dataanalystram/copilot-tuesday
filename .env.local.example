# -----------------------------------------------------------------------------
# MorphBoard — environment
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in your keys.
# DO NOT COMMIT `.env.local`.
# -----------------------------------------------------------------------------

# Local Ollama model for Studio. Requires: ollama serve && ollama pull qwen2.5:14b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_API_KEY=ollama

# Optional: GitHub token for higher rate limits (public endpoints work without).
# Create at https://github.com/settings/tokens (only needs `public_repo`).
GITHUB_TOKEN=

# MCP Apps. Excalidraw is enabled by default for the showcase storyboard.
MCP_APPS_ENABLE_EXCALIDRAW_DEMO=true

# Optional extra MCP App servers.
# Either JSON:
# MCP_APP_SERVERS=[{"type":"http","url":"https://example.com/mcp","serverId":"example","agentId":"default"}]
# Or comma-separated HTTP URLs:
# MCP_APP_SERVERS=https://example.com/mcp,https://another.example/mcp
MCP_APP_SERVERS=

# Dev flags
NEXT_PUBLIC_DEFAULT_REPO=vercel/next.js
